# Canvas AI — Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit the real .env file to version control.

# ---------------------------------------------------------------------------
# Supabase — New API key format (publishable + secret, not anon/service role)
# Dashboard → Project Settings → API → Project API keys
# ---------------------------------------------------------------------------
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Publishable key — safe for use in browser / client bundles
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>

# Secret key — server-side only, never expose to the browser
SUPABASE_SECRET=sb_secret_<your-secret-key>

# ---------------------------------------------------------------------------
# OpenAI
# Dashboard → API keys → Create new secret key
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-<your-openai-api-key>

# Model to use for chat completions. Supports reasoning models (e.g. o3-mini).
# Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Optional: custom base URL for OpenAI-compatible APIs
# Examples: Azure OpenAI, Groq, Together AI, LM Studio, Ollama, etc.
# Leave blank to use the default OpenAI endpoint (api.openai.com/v1)
OPENAI_BASE_URL=

# ---------------------------------------------------------------------------
# Optional — Canvas defaults
# ---------------------------------------------------------------------------
# Default workspace UUID used by /api/chat when workspaceId is not provided.
# Leave blank to auto-create a workspace on first use.
CANVAS_DEFAULT_WORKSPACE_ID=
